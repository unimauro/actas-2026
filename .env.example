# === OCR (Gemini) ===
# Obtén la llave GRATIS en https://aistudio.google.com  ->  "Get API key"
# Sin esta variable, la app corre en MODO DEMO (OCR simulado).
GEMINI_API_KEY=
# Modelo recomendado: gemini-flash-latest (funciona con llaves "AQ." de AI Studio)
GEMINI_MODEL=gemini-flash-latest

# === Supabase ===
# Sin estas variables, la app usa un store EN MEMORIA (solo para demo local).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Llave secreta (sb_secret_...): necesaria para que el admin edite estados (RLS).
SUPABASE_SECRET_KEY=

# === Panel admin ===
ADMIN_PASSWORD=

# === Google Analytics (opcional, visitantes) ===
NEXT_PUBLIC_GA_ID=
